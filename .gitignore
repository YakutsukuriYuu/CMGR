# Python cache/build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Local environments and editor files
.venv/
venv/
env/
.env
.env.*
.idea/
.vscode/
*.swp
*.swo

# Runtime logs
# Root-level experiment logs are tracked for reproducibility.
logs/
runs/
wandb/
tensorboard/

# Experiment outputs and checkpoints
# Track lightweight result files under outputs*, but keep checkpoints out.
outputs*/
!outputs*/
outputs*/**
!outputs*/**/
!outputs*/**/*.yaml
!outputs*/**/*.yml
!outputs*/**/*.json
!outputs*/**/*.csv
!outputs*/**/*.txt
checkpoints/
*.ckpt
*.pth
*.pt
*.onnx

# Local datasets and external pretrained dependencies
data/
datasets/
ModelNet40*/
ScanObjectNN*/
ShapeNet*/
CO3D*/
deps/
pretrained/

# Generated media or temporary files
*.tmp
*.bak
*.zip
*.tar
*.tar.gz
*.tgz
